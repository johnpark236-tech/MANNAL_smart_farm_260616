[Unit]
Description=MANNAL Smart Farm Backend
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/MANNAL_smart_farm_260616/backend
EnvironmentFile=/home/ubuntu/MANNAL_smart_farm_260616/backend/.env
ExecStart=/home/ubuntu/MANNAL_smart_farm_260616/backend/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
